{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小柴记",
  "mainBinaryName": "小柴记",
  "version": "0.2.22",
  "identifier": "com.tododesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build -w @todo/shared && npm run build -w @todo/desktop",
    "devUrl": "http://localhost:8090",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "小柴记",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "小柴记",
      "infoPlist": "Info.plist",
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4NTk3MjJEMDI4RjRFM0YKUldRL1RvOENMWEpaU0w4eXJaSXJjU25lL3pGczRnMWN5RVhlT01WdFk4MjEyUFE1dWVMcVJjZXMK",
      "endpoints": [
        "https://github.com/Hand-xieyicheng/hand-tododesk/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
