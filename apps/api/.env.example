NODE_ENV=development
PORT=4020
# Keep production behind Nginx. Use 0.0.0.0 only when the API must be reached directly on a LAN.
HOST=127.0.0.1
# APP_ORIGIN is also used for password reset email links and public print share links.
# Use the reachable frontend top-level domain/IP that printer apps can open.
APP_ORIGIN=http://192.168.1.100:8090
EXTRA_APP_ORIGINS=http://localhost:8090,http://127.0.0.1:8090,http://tauri.localhost,https://tauri.localhost,tauri://localhost
# API_PUBLIC_URL is used for email verification, avatar, and memo asset links.
# Use the reachable API domain/IP.
API_PUBLIC_URL=http://127.0.0.1:4020
API_VERSION=0.2.27
DESKTOP_MIN_VERSION=0.1.0
DESKTOP_LATEST_VERSION=0.2.27
DESKTOP_UPDATE_ENDPOINT=https://github.com/Hand-xieyicheng/hand-tododesk/releases/latest/download/latest.json
# Store user-uploaded avatar and memo images outside the release directory.
UPLOAD_STORAGE_DIR=/var/lib/tododesk/uploads
FEATURE_FLAGS_JSON=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=todoDesk
DB_USER=root
DB_PASSWORD=
DATABASE_URL=mysql://root:password@localhost:3306/todoDesk
JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="小柴记 <noreply@tododesk.local>"
