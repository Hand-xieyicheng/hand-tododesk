generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum TaskPriority {
  IMPORTANT_URGENT
  IMPORTANT_NOT_URGENT
  NOT_IMPORTANT_URGENT
  NOT_IMPORTANT_NOT_URGENT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum TaskExceptionStatus {
  SKIPPED
  COMPLETED
  RESCHEDULED
}

enum PomodoroStatus {
  RUNNING
  COMPLETED
  CANCELLED
}

enum UserGender {
  PRIVATE
  MALE
  FEMALE
  OTHER
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  passwordHash       String
  name               String?
  gender             UserGender               @default(PRIVATE)
  avatarPath         String?
  emailVerifiedAt    DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  tasks              Task[]
  tags               Tag[]
  refreshTokens      RefreshToken[]
  emailTokens        EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  themePreference    UserThemePreference?
  pomodoroSessions   PomodoroSession[]
  memos              Memo[]
  memoAssets         MemoAsset[]
  anniversaryEvents  AnniversaryEvent[]
  habits             Habit[]
  habitCheckIns      HabitCheckIn[]
  printShares        PrintShare[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id                String             @id @default(cuid())
  userId            String
  title             String
  notes             String?            @db.Text
  dueAt             DateTime?
  priority          TaskPriority       @default(IMPORTANT_NOT_URGENT)
  status            TaskStatus         @default(TODO)
  sortOrder         Int?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurrenceRule    RecurrenceRule?
  exceptions        TaskException[]
  tags              TaskTag[]
  pomodoroSessions  PomodoroSession[]

  @@index([userId, dueAt])
  @@index([userId, status])
  @@index([userId, sortOrder, createdAt, id])
}

model Tag {
  id        String    @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     TaskTag[]

  @@unique([userId, name])
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model SchemaMarker {
  key       String   @id
  createdAt DateTime @default(now())
}

model RecurrenceRule {
  id        String              @id @default(cuid())
  taskId    String              @unique
  frequency RecurrenceFrequency
  interval  Int                 @default(1)
  until     DateTime?
  count     Int?
  byWeekday Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  task      Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskException {
  id              String              @id @default(cuid())
  taskId          String
  occurrenceDate  DateTime
  status          TaskExceptionStatus
  rescheduledDate DateTime?
  createdAt       DateTime            @default(now())
  task            Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, occurrenceDate])
  @@index([taskId])
}

model PomodoroSession {
  id              String         @id @default(cuid())
  userId          String
  taskId          String
  status          PomodoroStatus @default(RUNNING)
  durationMinutes Int
  actualMinutes   Int?
  startedAt       DateTime       @default(now())
  endedAt         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([taskId, status])
}

model Memo {
  id              String      @id @default(cuid())
  userId          String
  title           String
  contentHtml     String      @db.MediumText
  excerpt         String?     @db.VarChar(500)
  isPinned        Boolean     @default(false)
  archivedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets          MemoAsset[]

  @@index([userId, isPinned])
  @@index([userId, updatedAt])
  @@index([userId, archivedAt])
}

model MemoAsset {
  id        String   @id @default(cuid())
  memoId    String
  userId    String
  filename  String
  mimeType  String
  sizeBytes Int
  width     Int?
  height    Int?
  path      String
  createdAt DateTime @default(now())
  memo      Memo     @relation(fields: [memoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([memoId])
  @@index([userId])
}

model AnniversaryEvent {
  id           String   @id @default(cuid())
  userId       String
  title        String
  notes        String?  @db.Text
  category     String
  date         String   @db.VarChar(10)
  repeat       String   @default("NONE")
  direction    String   @default("AUTO")
  cardStyle    String   @default("lavender")
  calendarType String   @default("SOLAR")
  lunarMonth   Int?
  lunarDay     Int?
  solarTerm    String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, category, date])
  @@index([userId, date])
}

model Habit {
  id          String         @id @default(cuid())
  userId      String
  title       String
  notes       String?        @db.Text
  icon        String         @default("Smile")
  color       String         @default("mint")
  frequency   String
  interval    Int            @default(1)
  weekDays    Json?
  monthDays   Json?
  startDate   String         @db.VarChar(10)
  endDate     String?        @db.VarChar(10)
  sortOrder   Int            @default(0)
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns    HabitCheckIn[]

  @@index([userId, archivedAt, sortOrder])
  @@index([userId, sortOrder])
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      String   @db.VarChar(10)
  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@index([habitId, date])
}

model UserThemePreference {
  userId             String   @id
  themeId            String   @default("warm-paper")
  titleColor         String   @default("app-teal")
  footerVisible      Boolean  @default(true)
  footerType         String   @default("sea")
  showCompletedTasks Boolean  @default(true)
  taskViewMode       String   @default("list")
  taskCardDisplayMode String   @default("full")
  floatingCardThemeId String   @default("warm-paper")
  appCloseBehavior   String   @default("hide")
  displaySize        String   @default("default")
  visibleSidebarModules String @default("tasks,memos,anniversaries,habits,calendar,pomodoro")
  sidebarCollapsed   Boolean  @default(false)
  printButtonEnabled Boolean  @default(false)
  fontFamily         String   @default("system")
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrintShare {
  id             String   @id @default(cuid())
  userId         String
  tokenHash      String   @unique
  sourceType     String
  sourceJson     Json
  configJson     Json
  expiresAt      DateTime
  revokedAt      DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}
